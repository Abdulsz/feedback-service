{
  "name": "@devfeedback/react-widget",
  "version": "0.1.1",
  "description": "A distributable feedback widget for collecting user feedback",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:embed": "vite build --config vite.embed.config.mts",
    "build:all": "npm run build && npm run build:embed",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "5.4.2",
    "vite": "^5.1.0",
    "vite-plugin-dts": "^3.7.0"
  },
  "dependencies": {
    "@devfeedback/react-widget": "^0.1.1"
  }
}
